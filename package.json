{
  "name": "blinkbasket",
  "type": "module",
  "version": "1.0.0",
  "description": "Ecommerce website - BlinkBasket",
  "main": "index.js",
  "scripts": {
    "build": "cd frontend && npm install && npm run build",
    "start": "nodemon --watch backend --exec node --experimental-modules backend/server.js",
    "server": "set NODE_OPTIONS=--openssl-legacy-provider && nodemon --watch backend --exec node --experimental-modules backend/server.js",
    "client": "set NODE_OPTIONS=--openssl-legacy-provider && cd frontend && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/basir/blinkbasket.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/basir/blinkbasket/issues"
  },
  "homepage": "https://github.com/basir/blinkbasket#readme",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^7.9.0",
    "eslint-plugin-react": "^7.21.2",
    "nodemon": "^2.0.4"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^8.5.1",
    "mailgun-js": "^0.22.0",
    "mongodb-memory-server": "^10.1.3",
    "mongoose": "^6.0.13",
    "multer": "^1.4.3",
    "socket.io": "^4.4.0"
  }
}
